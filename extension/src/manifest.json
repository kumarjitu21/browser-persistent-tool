{
  "manifest_version": 3,
  "name": "Workspace Memory",
  "version": "0.1.0",
  "description": "Automatic workspace snapshots for session recovery and context switching.",
  "permissions": ["tabs", "storage", "alarms"],
  "host_permissions": ["http://127.0.0.1:8000/*", "http://localhost:8000/*"],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "action": {
    "default_title": "Workspace Memory",
    "default_popup": "src/popup.html"
  }
}
